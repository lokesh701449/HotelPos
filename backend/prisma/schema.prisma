datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  MANAGER
  WAITER
  CHEF
  CASHIER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  BILLING
}

enum OrderStatus {
  OPEN
  PREPARING
  READY
  SERVED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum KitchenStatus {
  PENDING
  PREPARING
  READY
  SERVED
}

model Tenant {
  id             String          @id @default(uuid())
  name           String
  brandName      String
  address        String
  createdAt      DateTime        @default(now())
  users          User[]
  categories     Category[]
  menuItems      MenuItem[]
  tables         Table[]
  orders         Order[]
  payments       Payment[]
  kitchenTickets KitchenTicket[]
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())
  orders    Order[]
}

model Category {
  id        String     @id @default(uuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime   @default(now())
  menuItems MenuItem[]
}

model MenuItem {
  id          String      @id @default(uuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String
  price       Float
  prepTime    Int
  veg         Boolean
  available   Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
}

model Table {
  id        String      @id @default(uuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number    Int
  capacity  Int
  status    TableStatus @default(AVAILABLE)
  createdAt DateTime    @default(now())
  orders    Order[]
}

model Order {
  id             String          @id @default(uuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tableId        String
  table          Table           @relation(fields: [tableId], references: [id], onDelete: Cascade)
  waiterId       String
  waiter         User            @relation(fields: [waiterId], references: [id], onDelete: Cascade)
  status         OrderStatus     @default(OPEN)
  subtotal       Float
  tax            Float
  total          Float
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orderItems     OrderItem[]
  payments       Payment[]
  kitchenTickets KitchenTicket[]
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantity   Int
  notes      String?
  price      Float
}

model Payment {
  id                   String        @id @default(uuid())
  tenantId             String
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId              String
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method               PaymentMethod
  amount               Float
  status               PaymentStatus @default(PENDING)
  transactionReference String?
  createdAt            DateTime      @default(now())
}

model KitchenTicket {
  id        String        @id @default(uuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    KitchenStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
